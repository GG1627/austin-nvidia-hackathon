# Copy to .env and fill in. All keys are OPTIONAL for Agent 3 — without
# NVIDIA_API_KEY the system uses its deterministic recommendation engine.

# NVIDIA NIM inference (all agents)
NVIDIA_API_KEY=
# Override the default model (meta/llama-3.1-70b-instruct) if desired:
# NIM_MODEL=meta/llama-3.1-70b-instruct

# Agent 2 — research connectors
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
TAVILY_API_KEY=

# Optional fallback
OPENAI_API_KEY=
