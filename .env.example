# --- Agent 1: Memory & Knowledge Layer -------------------------------------

# Supabase project (apply db/schema.sql before running anything against this).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Nemotron via an OpenAI-compatible vLLM / NVIDIA NIM endpoint — the
# consolidation model that proposes new_hypotheses/evidence_updates/contradictions.
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/llama-3.1-nemotron-70b-instruct

# Featherless AI — second model for cross-model calibration, and the
# embedding provider for episodes/insights. Must produce EMBEDDING_DIM=1024
# vectors to match db/schema.sql's vector(1024) columns.
FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_MODEL=Qwen/Qwen2.5-72B-Instruct
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

# --- Agents 2 & 3 (owned by other positions) --------------------------------
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# TAVILY_API_KEY=
