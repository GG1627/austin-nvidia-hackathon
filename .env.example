# --- Agent 1: Memory & Knowledge Layer -------------------------------------

# Supabase project (apply db/schema.sql before running anything against this).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Nemotron via an OpenAI-compatible vLLM / NVIDIA NIM endpoint — the
# consolidation model that proposes new_hypotheses/evidence_updates/contradictions.
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/llama-3.1-nemotron-70b-instruct

# Self-hosted vLLM — second model for cross-model calibration. Leave the
# base URL empty until a vLLM server is actually running; calibration then
# degrades gracefully to single-model support factors.
#   vllm serve Qwen/Qwen2.5-7B-Instruct --port 8001
VLLM_CALIBRATE_BASE_URL=
VLLM_CALIBRATE_MODEL=Qwen/Qwen2.5-7B-Instruct
VLLM_CALIBRATE_API_KEY=

# Self-hosted vLLM — embedding provider for episodes/insights. Must produce
# EMBEDDING_DIM=1024 vectors to match db/schema.sql's vector(1024) columns.
#   vllm serve Qwen/Qwen3-Embedding-0.6B --port 8002 --task embed
VLLM_EMBEDDING_BASE_URL=
VLLM_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
VLLM_EMBEDDING_API_KEY=

# --- Agent 2: Research & Opportunity Monitor --------------------------------

# Agent 2 optional live sources
OLLAMA_URL=http://localhost:11434
# NemoClaw is the runtime; use a real Nemotron model for inference.
OLLAMA_MODEL=nemotron-3-nano:4b
# OpenAI-compatible inference endpoint. Choose exactly one runtime route:
# - vLLM on this laptop (from WSL): http://localhost:8000/v1
# - NemoClaw's controlled inference gateway: https://inference.local/v1
# INFERENCE_BASE_URL=http://localhost:8000/v1
# YouTube: create an API key in Google Cloud after enabling YouTube Data API v3.
YOUTUBE_API_KEY=
YOUTUBE_QUERY=AI agents LLM NVIDIA developer tools
YOUTUBE_LOOKBACK_HOURS=168

# X: create a project/app in the X Developer Portal and copy its Bearer Token.
# X is disabled by default because X recent search uses paid API credits.
ENABLE_X=false
X_BEARER_TOKEN=
X_QUERY=(AI agents OR LLM OR NVIDIA OR "developer tools") lang:en -is:retweet

# Agent 3 owns AGENT_RUN_ID; Agent 2 reads it for its persistent heartbeat.
AGENT2_HEARTBEAT_SECONDS=300
# AGENT_RUN_ID=
# AGENT2_HANDOFF_DIR=memory/agent2

REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
TAVILY_API_KEY=

# --- Agent 3: Strategist -----------------------------------------------------
# All keys below are OPTIONAL — without NVIDIA_API_KEY, Agent 3 falls back to
# its deterministic recommendation engine. NVIDIA_API_KEY is shared with the
# Agent 1 section above; NIM_MODEL overrides the model Agent 3 requests.
# NIM_MODEL=meta/llama-3.1-70b-instruct

# Optional fallback inference provider for Agent 3.
OPENAI_API_KEY=
