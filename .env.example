# Agent 2 optional live sources
OLLAMA_URL=http://localhost:11434
# NemoClaw is the runtime; use a real Nemotron model for inference.
OLLAMA_MODEL=nemotron-3-nano:4b
# OpenAI-compatible inference endpoint. Choose exactly one runtime route:
# - vLLM on this laptop (from WSL): http://localhost:8000/v1
# - NemoClaw's controlled inference gateway: https://inference.local/v1
# INFERENCE_BASE_URL=http://localhost:8000/v1
# YouTube: create an API key in Google Cloud after enabling YouTube Data API v3.
YOUTUBE_API_KEY=
YOUTUBE_QUERY=AI agents LLM NVIDIA developer tools
YOUTUBE_LOOKBACK_HOURS=168

# X: create a project/app in the X Developer Portal and copy its Bearer Token.
# X is disabled by default because X recent search uses paid API credits.
ENABLE_X=false
X_BEARER_TOKEN=
X_QUERY=(AI agents OR LLM OR NVIDIA OR "developer tools") lang:en -is:retweet

# Agent 3 owns AGENT_RUN_ID; Agent 2 reads it for its persistent heartbeat.
AGENT2_HEARTBEAT_SECONDS=300
# AGENT_RUN_ID=
# AGENT2_HANDOFF_DIR=memory/agent2
